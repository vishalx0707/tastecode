{
  "name": "@tastecode/plugin",
  "version": "0.3.0",
  "description": "Portable coding-taste plugin for any AI coding agent. Use any agent. Keep your coding taste.",
  "keywords": [
    "ai",
    "coding-agent",
    "claude-code",
    "codex",
    "cursor",
    "cline",
    "aider",
    "opencode",
    "cli",
    "taste",
    "prompt",
    "wrapper"
  ],
  "homepage": "https://github.com/vishalx0707/tastecode#readme",
  "bugs": {
    "url": "https://github.com/vishalx0707/tastecode/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vishalx0707/tastecode.git"
  },
  "author": "vishalx0707",
  "license": "MIT",
  "type": "module",
  "bin": {
    "tastecode": "dist/index.js",
    "tastecode-plugin": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
